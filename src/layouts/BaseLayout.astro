---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'Watch Haikus', description = 'Reading room for watches.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — Watch Haikus</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,ital,wght@9..144,0,300;9..144,0,400;9..144,0,500;9..144,1,300;9..144,1,400;9..144,1,500&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      --p:    #F2F0EA;
      --p2:   #E8E4DA;
      --ink:  #1C1A14;
      --rule: #D0CAB8;
      --mute: #8A8272;
      --g:    #2F4438;
      --gs:   #A8C5A0;
      --gd:   #6E9178;
      --warm: #9C6B43;
      --ff:   'Fraunces', Georgia, serif;
      --fm:   'Spline Sans Mono', 'Courier New', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; overflow-x: hidden; }
    body {
      background: var(--p);
      color: var(--ink);
      font-family: var(--ff);
      font-size: 18px;
      line-height: 1.6;
      overflow-x: hidden;
    }
    a { color: inherit; }

    /* ── Transitions ── */
    a, button { transition: color .15s ease, background-color .2s ease, border-color .2s ease, opacity .15s ease; }

    /* ── Buttons ── */
    .r-btn {
      font-family: var(--fm);
      font-size: 11px;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--g);
      text-decoration: none;
      border: 1px solid var(--g);
      padding: 10px 22px;
      display: inline-block;
      cursor: pointer;
      background: transparent;
    }
    .r-btn:hover { background: var(--g); color: var(--p); }

    .r-btn-inv {
      color: var(--p);
      border-color: rgba(255,255,255,.25);
      background: transparent;
    }
    .r-btn-inv:hover { background: var(--p); color: var(--g); border-color: var(--p); }

    /* ── Cards ── */
    .r-card { transition: background-color .2s ease; cursor: pointer; }
    .r-card:hover { background-color: var(--p2); }

    /* ── Label line style ── */
    .r-label {
      font-family: var(--fm);
      font-size: 10px;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--g);
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .r-label::before {
      content: '';
      display: inline-block;
      width: 20px;
      height: 1px;
      background: currentColor;
      flex-shrink: 0;
    }

    /* ── Layout classes (desktop defaults) ── */
    .r-grid-3      { display: grid; grid-template-columns: repeat(3, 1fr); }
    .r-grid-essay  { display: grid; grid-template-columns: 80px 1fr; align-items: start; }
    .r-featured    { display: grid; grid-template-columns: 110px 1fr; align-items: start; }
    .r-footer      { display: flex; align-items: center; justify-content: space-between; padding: 36px 48px; }
    .r-dateline    { display: flex; align-items: center; justify-content: space-between; padding: 0 48px; height: 34px; }
    .r-pad         { padding: 0 48px; }
    .r-pad-hero    { padding: 88px 64px 80px; }
    .r-section-hero { padding: 72px 64px 64px; }
    .r-dark-section { padding: 72px 64px; }
    .r-creed       { padding: 96px 64px 80px; }

    /* ── Article layout ── */
    .r-article-header { padding: 80px 64px 64px; }
    .r-article-body   { padding: 56px 64px 48px; font-size: 19px; line-height: 1.85; }
    .r-article-back   { padding: 0 64px 56px; }
    .r-article-img    { padding: 0 64px; }

    /* ── Mobile overrides ── */
    @media (max-width: 768px) {
      .site-header { padding: 0 20px; height: 50px; }
      .site-header .logo { font-size: 13px; }
      .site-header nav a { padding: 0 8px; font-size: 10px; height: 50px; }

      .r-pad { padding: 28px 24px; }
      .r-pad-hero { padding: 44px 24px 40px; }
      .r-section-hero { padding: 40px 24px 36px; }
      .r-dark-section { padding: 48px 24px; }
      .r-creed { padding: 56px 24px 48px; }

      .r-dateline { flex-direction: column; align-items: flex-start; gap: 4px; padding: 10px 24px; height: auto; }
      .r-footer { padding: 32px 24px; }

      .r-hero-title { font-size: 52px !important; }
      .r-haiku-hero { font-size: 36px !important; padding-left: 20px !important; }
      .r-haiku-title { font-size: 52px !important; }
      .r-haiku-excerpt { font-size: 17px !important; }

      .r-grid-3 { grid-template-columns: 1fr; }
      .r-grid-3 > * { border-right: none; border-bottom: 1px solid var(--rule); }
      .r-grid-3 > *:last-child { border-bottom: none; }

      .r-grid-essay { grid-template-columns: 1fr; }
      .r-grid-essay .r-essay-num { display: none; }
      .r-grid-essay .r-essay-body { padding-left: 0; }

      .r-featured { grid-template-columns: 1fr; }
      .r-featured-num { display: none; }
      .r-featured-body { padding-left: 0; }

      .r-creed { font-size: 32px !important; padding: 56px 24px !important; }

      .r-footer { flex-direction: column; align-items: flex-start; gap: 20px; padding: 32px 24px; }

      .r-section-hero { padding: 36px 24px 32px; }
      .r-section-hero .r-section-title { font-size: 32px !important; }

      .r-article-header { padding: 36px 24px 28px; }
      .r-article-header h1 { font-size: 32px; }
      .r-article-body { padding: 24px 24px 36px; font-size: 16px; line-height: 1.7; }
      .r-article-back { padding: 0 24px 36px; }
      .r-article-img { padding: 0 24px; }

      .r-dark-section { padding: 48px 24px !important; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
