---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(essay => ({
    params: { slug: essay.slug },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await essay.render();
---
<BaseLayout title={essay.data.title} description={essay.data.subtitle}>

  <Header active="Essays" />

  <div class="r-article-header" style="padding:80px 64px 64px;border-bottom:1px solid var(--rule);max-width:820px;margin:0 auto;">
    <div style="font-family:var(--fm);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--warm);margin-bottom:28px;display:flex;align-items:center;gap:10px;">
      <span style="display:inline-block;width:14px;height:1px;background:var(--warm);flex-shrink:0;"></span>
      {essay.data.series} · {essay.data.readingTime}
    </div>
    <h1 style="font-family:var(--ff);font-size:56px;font-weight:400;line-height:1.1;color:var(--ink);margin-bottom:20px;letter-spacing:-.01em;">{essay.data.title}</h1>
    {essay.data.subtitle && (
      <p style="font-family:var(--ff);font-size:21px;font-style:italic;font-weight:300;color:var(--mute);line-height:1.6;max-width:600px;">{essay.data.subtitle}</p>
    )}
  </div>

  {essay.data.image && (
    <div style="max-width:820px;margin:0 auto;padding:0 64px;">
      <figure style="margin:0;border-top:1px solid var(--rule);">
        <img
          src={essay.data.image}
          alt={essay.data.imageAlt ?? essay.data.title}
          style="width:100%;display:block;aspect-ratio:16/9;object-fit:cover;"
        />
        {essay.data.imageAlt && (
          <figcaption style="font-family:var(--fm);font-size:10px;letter-spacing:.08em;color:var(--mute);padding:10px 0 0;text-transform:uppercase;">{essay.data.imageAlt}</figcaption>
        )}
      </figure>
    </div>
  )}

  <article class="r-article-body" style="padding:56px 64px 48px;max-width:820px;margin:0 auto;font-family:var(--ff);font-size:19px;line-height:1.85;color:var(--ink);">
    <style>
      article p { margin-bottom: 1.7em; }
      article p:first-child::first-letter { font-size: 3.2em; font-weight: 300; float: left; line-height: .85; margin-right: .08em; margin-top: .04em; color: var(--g); font-style: italic; }
      article em { font-style: italic; }
      article strong { font-weight: 500; }
      article h2 { font-family: var(--ff); font-size: 28px; font-weight: 400; line-height: 1.3; margin: 2.5em 0 1em; color: var(--ink); }
      article blockquote { border-left: 3px solid var(--g); padding-left: 28px; margin: 2em 0; font-style: italic; color: var(--mute); }
    </style>
    <Content />
  </article>

  <div class="r-article-back" style="padding:0 64px 56px;max-width:820px;margin:0 auto;border-bottom:1px solid var(--rule);">
    <a href="/essays" class="r-label" style="text-decoration:none;color:var(--g);">All essays</a>
  </div>

  <footer class="r-footer" style="padding:36px 48px;background:var(--g);">
    <a href="/" style="text-decoration:none;font-family:var(--ff);font-size:14px;letter-spacing:.08em;text-transform:uppercase;color:var(--p);display:flex;align-items:center;gap:10px;">
      <span style="display:inline-block;width:7px;height:7px;background:var(--gs);flex-shrink:0;"></span>
      <span style="font-weight:300;">WATCH</span><span style="font-weight:500;color:var(--gs);">HAIKUS</span>
    </a>
    <span style="font-family:var(--ff);font-size:14px;font-style:italic;color:var(--gd);">Reading room for watches.</span>
    <nav style="display:flex;gap:28px;flex-wrap:wrap;">
      <a href="/essays" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">Essays</a>
      <a href="/haikus" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">Haikus</a>
      <a href="/available" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">Available</a>
      <a href="/about" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">About</a>
    </nav>
  </footer>

</BaseLayout>
