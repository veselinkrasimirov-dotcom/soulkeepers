---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(essay => ({
    params: { slug: essay.slug },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await essay.render();

const allEssays = await getCollection('essays');
const others = allEssays
  .filter(e => e.slug !== essay.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);

const dateFormatted = new Date(essay.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---
<BaseLayout title={essay.data.title} description={essay.data.subtitle}>

  <Header active="Essays" />

  <div class="r-article-header" style="border-bottom:1px solid var(--rule);max-width:820px;margin:0 auto;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:8px;">
      <div style="font-family:var(--fm);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--warm);display:flex;align-items:center;gap:10px;">
        <span style="display:inline-block;width:14px;height:1px;background:var(--warm);flex-shrink:0;"></span>
        {essay.data.series} · {essay.data.readingTime}
      </div>
      <span style="font-family:var(--fm);font-size:10px;letter-spacing:.08em;color:var(--mute);">{dateFormatted}</span>
    </div>
    <h1 style="font-family:var(--ff);font-size:56px;font-weight:400;line-height:1.1;color:var(--ink);margin-bottom:20px;letter-spacing:-.01em;">{essay.data.title}</h1>
    {essay.data.subtitle && (
      <p style="font-family:var(--ff);font-size:21px;font-style:italic;font-weight:300;color:var(--mute);line-height:1.6;max-width:600px;">{essay.data.subtitle}</p>
    )}
  </div>

  {essay.data.image && (
    <div class="r-article-img" style="max-width:820px;margin:0 auto;">
      <figure style="margin:0;border-top:1px solid var(--rule);">
        <img
          src={essay.data.image}
          alt={essay.data.imageAlt ?? essay.data.title}
          style="width:100%;display:block;aspect-ratio:16/9;object-fit:cover;"
        />
        {essay.data.imageAlt && (
          <figcaption style="font-family:var(--fm);font-size:10px;letter-spacing:.08em;color:var(--mute);padding:10px 0 0;text-transform:uppercase;">{essay.data.imageAlt}</figcaption>
        )}
      </figure>
    </div>
  )}

  <article class="r-article-body" style="max-width:820px;margin:0 auto;font-family:var(--ff);color:var(--ink);">
    <style>
      article p { margin-bottom: 1.7em; }
      article p:first-child::first-letter { font-size: 3.2em; font-weight: 300; float: left; line-height: .85; margin-right: .08em; margin-top: .04em; color: var(--g); font-style: italic; }
      article em { font-style: italic; }
      article strong { font-weight: 500; }
      article h2 { font-family: var(--ff); font-size: 28px; font-weight: 400; line-height: 1.3; margin: 2.5em 0 1em; color: var(--ink); }
      article blockquote { border-left: 3px solid var(--g); padding-left: 28px; margin: 2em 0; font-style: italic; color: var(--mute); }
    </style>
    <Content />
  </article>

  <!-- Read more -->
  {others.length > 0 && (
    <div style="border-top:1px solid var(--rule);max-width:820px;margin:0 auto;" class="r-article-back">
      <div class="r-label" style="color:var(--gd);margin-bottom:28px;">More essays</div>
      <div class="r-grid-3" style="grid-template-columns:repeat(2,1fr);">
        {others.map(other => (
          <a href={`/essays/${other.slug}`} class="r-card" style="text-decoration:none;padding:24px;border:1px solid var(--rule);display:block;">
            <div style="font-family:var(--fm);font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--warm);margin-bottom:10px;display:flex;align-items:center;gap:8px;">
              <span style="display:inline-block;width:10px;height:1px;background:var(--warm);flex-shrink:0;"></span>
              {other.data.series}
            </div>
            <div style="font-family:var(--ff);font-size:18px;font-weight:400;line-height:1.3;color:var(--ink);margin-bottom:8px;">{other.data.title}</div>
            {other.data.subtitle && (
              <div style="font-family:var(--ff);font-size:14px;font-style:italic;font-weight:300;color:var(--mute);line-height:1.5;">{other.data.subtitle}</div>
            )}
            <div style="font-family:var(--fm);font-size:9px;letter-spacing:.1em;color:var(--gd);margin-top:16px;text-transform:uppercase;">Read →</div>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="r-article-back" style="max-width:820px;margin:0 auto;border-bottom:1px solid var(--rule);">
    <a href="/essays" class="r-label" style="text-decoration:none;color:var(--g);">All essays</a>
  </div>

  <Footer />

</BaseLayout>
