---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';

const essays = await getCollection('essays');
const haikus = await getCollection('haikus');
const watches = await getCollection('watches');

const featuredEssay = essays.find(e => e.data.featured);
const latestHaikus = haikus.sort((a, b) => b.data.number - a.data.number).slice(0, 3);
const availableWatches = watches.filter(w => w.data.status === 'available');

function excerpt(body: string) {
  const first = body.split('\n\n')[0].trim();
  return first.length > 180 ? first.slice(0, 180).trimEnd() + '…' : first;
}
---
<BaseLayout title="The Bench">

  <Header active="The Bench" />

  <!-- Editorial strip -->
  <div class="r-dateline" style="border-bottom:1px solid var(--rule);">
    <span style="font-family:var(--fm);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--mute);">The Bench — Vol. 01 · № {latestHaikus[0]?.data.number}</span>
    <span style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);">Essays ongoing · Vienna</span>
  </div>

  <!-- Hero -->
  {latestHaikus[0] && (
    <section class="r-pad-hero" style="border-bottom:1px solid var(--rule);position:relative;overflow:hidden;">
      <!-- Background watermark number -->
      <div aria-hidden="true" style="position:absolute;right:-20px;top:50%;transform:translateY(-50%);font-family:var(--ff);font-size:320px;font-weight:300;color:var(--g);opacity:.05;line-height:1;pointer-events:none;user-select:none;letter-spacing:-.02em;">
        {String(latestHaikus[0].data.number).padStart(3,'0')}
      </div>

      <div class="r-label" style="margin-bottom:44px;color:var(--gd);">
        Haiku · {String(latestHaikus[0].data.number).padStart(3,'0')} · {latestHaikus[0].data.watch ?? latestHaikus[0].data.brand}
      </div>

      {latestHaikus[0].data.title ? (
        <div style="max-width:860px;">
          <h1 class="r-haiku-title" style="font-family:var(--ff);font-size:88px;font-weight:400;font-style:italic;line-height:1.05;color:var(--ink);margin-bottom:32px;letter-spacing:-.02em;">{latestHaikus[0].data.title}</h1>
          <p class="r-haiku-excerpt" style="font-family:var(--ff);font-size:20px;font-weight:300;line-height:1.75;color:var(--mute);margin-bottom:40px;max-width:600px;">{excerpt(latestHaikus[0].body)}</p>
          <a href={`/haikus/${latestHaikus[0].slug}`} class="r-btn">Read</a>
        </div>
      ) : (
        <div style="max-width:860px;">
          <div class="r-haiku-hero" style="font-family:var(--ff);font-size:72px;font-weight:300;font-style:italic;line-height:1.35;color:var(--ink);border-left:3px solid var(--g);padding-left:40px;">
            {latestHaikus[0].body.split('\n').filter((l: string) => l.trim()).map((line: string) => (
              <>{line}<br /></>
            ))}
          </div>
        </div>
      )}

      <div style="margin-top:48px;font-family:var(--fm);font-size:10px;letter-spacing:.1em;color:var(--mute);text-transform:uppercase;display:flex;align-items:center;gap:12px;">
        <span style="display:inline-block;width:20px;height:1px;background:var(--mute);flex-shrink:0;"></span>
        {latestHaikus[0].data.brand}
      </div>
    </section>
  )}

  <!-- Featured Essay — dark section -->
  {featuredEssay && (
    <section class="r-dark-section" style="background:var(--g);position:relative;overflow:hidden;">
      <div aria-hidden="true" style="position:absolute;right:48px;bottom:-32px;font-family:var(--ff);font-size:260px;font-weight:300;color:#fff;opacity:.04;line-height:1;pointer-events:none;letter-spacing:-.02em;">
        {String(featuredEssay.data.seriesNumber).padStart(2,'0')}
      </div>
      <div class="r-label" style="margin-bottom:24px;color:var(--gd);">
        Featured Essay · {featuredEssay.data.series}
      </div>
      <h2 style="font-family:var(--ff);font-size:46px;font-weight:400;line-height:1.2;color:var(--p);margin-bottom:18px;max-width:760px;letter-spacing:-.01em;">{featuredEssay.data.title}</h2>
      <p style="font-family:var(--ff);font-size:18px;font-style:italic;font-weight:300;color:var(--gs);line-height:1.7;margin-bottom:40px;max-width:560px;">{featuredEssay.data.subtitle}</p>
      <a href={`/essays/${featuredEssay.slug}`} class="r-btn-inv r-btn">Read essay</a>
    </section>
  )}

  <!-- Three haiku cards -->
  <div class="r-grid-3" style="border-bottom:1px solid var(--rule);">
    {latestHaikus.map((haiku, i) => (
      <a href={`/haikus/${haiku.slug}`} class="r-card" style={`text-decoration:none;padding:44px 36px;display:block;${i < 2 ? 'border-right:1px solid var(--rule);' : ''}`}>
        <div class="r-label" style="margin-bottom:22px;color:var(--gd);">
          {String(haiku.data.number).padStart(3,'0')}
        </div>
        {haiku.data.title ? (
          <>
            <div style="font-family:var(--ff);font-size:22px;font-weight:400;line-height:1.3;color:var(--ink);margin-bottom:14px;">{haiku.data.title}</div>
            <div style="font-family:var(--ff);font-size:15px;font-style:italic;font-weight:300;line-height:1.7;color:var(--mute);">{excerpt(haiku.body).slice(0,120)}…</div>
          </>
        ) : (
          <div style="font-family:var(--ff);font-size:19px;font-style:italic;font-weight:300;line-height:1.8;color:var(--ink);">
            {haiku.body.split('\n').filter((l: string) => l.trim()).map((line: string) => (
              <>{line}<br /></>
            ))}
          </div>
        )}
        <div style="margin-top:22px;font-family:var(--fm);font-size:10px;letter-spacing:.08em;color:var(--mute);display:flex;align-items:center;gap:10px;">
          <span style="display:inline-block;width:14px;height:1px;background:var(--mute);flex-shrink:0;"></span>
          {haiku.data.brand}{haiku.data.watch ? ` · ${haiku.data.watch}` : ''}
        </div>
      </a>
    ))}
  </div>

  <!-- Available watches: hidden until selling begins -->

  <!-- Creed -->
  <section style="background:var(--ink);position:relative;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;right:48px;top:50%;transform:translateY(-50%);font-family:var(--fm);font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:#fff;opacity:.06;writing-mode:vertical-rl;letter-spacing:.3em;">WATCH HAIKUS · VIENNA</div>
    <div class="r-creed" style="font-family:var(--ff);font-size:56px;font-style:italic;font-weight:300;line-height:1.35;color:var(--p);max-width:880px;">
      We don't describe watches.<br>
      We <em style="font-style:normal;color:var(--gs);font-weight:400;">argue</em> them.
    </div>
    <div class="r-pad" style="padding-bottom:48px;font-family:var(--fm);font-size:10px;letter-spacing:.18em;color:#3a4a3e;text-transform:uppercase;">Vienna — content leads, selling lags</div>
  </section>

  <!-- Footer -->
  <footer class="r-footer" style="background:var(--g);">
    <a href="/" style="text-decoration:none;font-family:var(--ff);font-size:14px;letter-spacing:.08em;text-transform:uppercase;color:var(--p);display:flex;align-items:center;gap:10px;">
      <span style="display:inline-block;width:7px;height:7px;background:var(--gs);flex-shrink:0;"></span>
      <span style="font-weight:300;">WATCH</span><span style="font-weight:500;color:var(--gs);">HAIKUS</span>
    </a>
    <span style="font-family:var(--ff);font-size:14px;font-style:italic;color:var(--gd);">Reading room for watches.</span>
    <nav style="display:flex;gap:28px;flex-wrap:wrap;">
      <a href="/essays" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">Essays</a>
      <a href="/haikus" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">Haikus</a>
      <a href="/about" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">About</a>
    </nav>
  </footer>

</BaseLayout>
