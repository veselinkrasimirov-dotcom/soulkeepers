---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const haikus = await getCollection('haikus');
  return haikus.map(haiku => ({
    params: { slug: haiku.slug },
    props: { haiku },
  }));
}

const { haiku } = Astro.props;
const { Content } = await haiku.render();

const allHaikus = await getCollection('haikus');
const sorted = allHaikus.sort((a, b) => a.data.number - b.data.number);
const currentIndex = sorted.findIndex(h => h.slug === haiku.slug);
const prevHaiku = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextHaiku = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const dateFormatted = new Date(haiku.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---
<BaseLayout title={haiku.data.title ?? `Haiku ${haiku.data.number}`} description={`${haiku.data.brand}${haiku.data.watch ? ' · ' + haiku.data.watch : ''}`}>

  <Header active="Haikus" />

  <div class="r-article-header" style="border-bottom:1px solid var(--rule);max-width:820px;margin:0 auto;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:8px;">
      <div class="r-label" style="color:var(--gd);">Haiku · {String(haiku.data.number).padStart(3,'0')}</div>
      <span style="font-family:var(--fm);font-size:10px;letter-spacing:.08em;color:var(--mute);">{dateFormatted}</span>
    </div>
    <div style="font-family:var(--fm);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--warm);margin-bottom:28px;display:flex;align-items:center;gap:10px;">
      <span style="display:inline-block;width:14px;height:1px;background:var(--warm);flex-shrink:0;"></span>
      {haiku.data.brand}{haiku.data.watch ? ` · ${haiku.data.watch}` : ''}
    </div>

    {haiku.data.title ? (
      <h1 style="font-family:var(--ff);font-size:64px;font-weight:400;font-style:italic;line-height:1.1;color:var(--ink);letter-spacing:-.01em;">{haiku.data.title}</h1>
    ) : (
      <div style="font-family:var(--ff);font-size:44px;font-style:italic;font-weight:300;line-height:1.5;color:var(--ink);border-left:3px solid var(--g);padding-left:36px;">
        {haiku.body.split('\n').filter((l: string) => l.trim()).map((line: string) => (
          <>{line}<br /></>
        ))}
      </div>
    )}
  </div>

  {haiku.data.image && (
    <div class="r-article-img" style="max-width:820px;margin:0 auto;">
      <figure style="margin:0;border-top:1px solid var(--rule);">
        <img src={haiku.data.image} alt={haiku.data.imageAlt ?? (haiku.data.watch ?? haiku.data.brand)} style="width:100%;display:block;aspect-ratio:16/9;object-fit:cover;" />
        {haiku.data.imageAlt && (
          <figcaption style="font-family:var(--fm);font-size:10px;letter-spacing:.08em;color:var(--mute);padding:10px 0 0;text-transform:uppercase;">{haiku.data.imageAlt}</figcaption>
        )}
      </figure>
    </div>
  )}

  {haiku.data.title && (
    <article class="r-article-body" style="max-width:820px;margin:0 auto;font-family:var(--ff);color:var(--ink);">
      <style>
        article p { margin-bottom: 1.7em; }
        article p:first-child::first-letter { font-size: 3.2em; font-weight: 300; float: left; line-height: .85; margin-right: .08em; margin-top: .04em; color: var(--g); font-style: italic; }
        article em { font-style: italic; }
        article strong { font-weight: 500; }
      </style>
      <Content />
    </article>
  )}

  <!-- Prev / Next navigation -->
  <div class="r-article-back" style="max-width:820px;margin:0 auto;border-bottom:1px solid var(--rule);">
    <div style="display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:16px;">

      {prevHaiku ? (
        <a href={`/haikus/${prevHaiku.slug}`} style="text-decoration:none;display:block;">
          <div style="font-family:var(--fm);font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--mute);margin-bottom:6px;">← Older</div>
          <div style="font-family:var(--ff);font-size:15px;font-weight:400;color:var(--ink);line-height:1.3;">{prevHaiku.data.title ?? prevHaiku.data.brand}</div>
          <div style="font-family:var(--fm);font-size:9px;letter-spacing:.08em;color:var(--mute);margin-top:4px;">{prevHaiku.data.brand}</div>
        </a>
      ) : <div />}

      <a href="/haikus" class="r-label" style="text-decoration:none;color:var(--gd);white-space:nowrap;">All haikus</a>

      {nextHaiku ? (
        <a href={`/haikus/${nextHaiku.slug}`} style="text-decoration:none;display:block;text-align:right;">
          <div style="font-family:var(--fm);font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--mute);margin-bottom:6px;">Newer →</div>
          <div style="font-family:var(--ff);font-size:15px;font-weight:400;color:var(--ink);line-height:1.3;">{nextHaiku.data.title ?? nextHaiku.data.brand}</div>
          <div style="font-family:var(--fm);font-size:9px;letter-spacing:.08em;color:var(--mute);margin-top:4px;">{nextHaiku.data.brand}</div>
        </a>
      ) : <div />}

    </div>
  </div>

  <footer class="r-footer" style="background:var(--g);">
    <a href="/" style="text-decoration:none;font-family:var(--ff);font-size:14px;letter-spacing:.08em;text-transform:uppercase;color:var(--p);display:flex;align-items:center;gap:10px;">
      <span style="display:inline-block;width:7px;height:7px;background:var(--gs);flex-shrink:0;"></span>
      <span style="font-weight:300;">WATCH</span><span style="font-weight:500;color:var(--gs);">HAIKUS</span>
    </a>
    <span style="font-family:var(--ff);font-size:14px;font-style:italic;color:var(--gd);">Reading room for watches.</span>
    <nav style="display:flex;gap:28px;flex-wrap:wrap;">
      <a href="/essays" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">Essays</a>
      <a href="/haikus" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">Haikus</a>
      <a href="/about" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">About</a>
    </nav>
  </footer>

</BaseLayout>
