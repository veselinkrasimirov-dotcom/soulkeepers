---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';

const haikus = await getCollection('haikus');
const sorted = haikus.sort((a, b) => b.data.number - a.data.number);

function excerpt(body: string) {
  const first = body.split('\n\n')[0].trim();
  return first.length > 140 ? first.slice(0, 140).trimEnd() + '…' : first;
}
---
<BaseLayout title="Haikus">

  <Header active="Haikus" />

  <div class="r-dateline" style="border-bottom:1px solid var(--rule);">
    <span style="font-family:var(--fm);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--mute);">Haikus — {sorted.length} observations</span>
  </div>

  <section class="r-section-hero" style="border-bottom:1px solid var(--rule);">
    <div class="r-label" style="margin-bottom:28px;color:var(--gd);">Short form</div>
    <div class="r-section-title" style="font-family:var(--ff);font-size:52px;font-weight:300;font-style:italic;line-height:1.35;color:var(--ink);max-width:640px;">
      Single idea.<br>One watch, one argument.
    </div>
  </section>

  <div class="r-pad">
    {sorted.map((haiku) => (
      <a href={`/haikus/${haiku.slug}`} class="r-grid-essay r-card" style="text-decoration:none;border-bottom:1px solid var(--rule);padding:36px 0;">
        <div class="r-essay-num" style="padding-right:28px;border-right:1px solid var(--rule);">
          <div style="font-family:var(--fm);font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--gd);margin-bottom:10px;">№</div>
          <div style="font-family:var(--ff);font-size:52px;font-weight:300;color:var(--g);line-height:1;">{String(haiku.data.number).padStart(3,'0')}</div>
        </div>
        <div class="r-essay-body" style="padding-left:32px;">
          <div style="font-family:var(--fm);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--warm);margin-bottom:14px;display:flex;align-items:center;gap:10px;">
            <span style="display:inline-block;width:14px;height:1px;background:var(--warm);flex-shrink:0;"></span>
            {haiku.data.brand}{haiku.data.watch ? ` · ${haiku.data.watch}` : ''}
          </div>
          {haiku.data.title ? (
            <>
              <div style="font-family:var(--ff);font-size:26px;font-weight:400;line-height:1.25;color:var(--ink);margin-bottom:12px;">{haiku.data.title}</div>
              <div style="font-family:var(--ff);font-size:16px;font-style:italic;font-weight:300;color:var(--mute);line-height:1.65;">{excerpt(haiku.body)}</div>
            </>
          ) : (
            <div style="font-family:var(--ff);font-size:21px;font-style:italic;font-weight:300;line-height:1.75;color:var(--ink);">
              {haiku.body.split('\n').filter((l: string) => l.trim()).map((line: string) => (
                <>{line}<br /></>
              ))}
            </div>
          )}
        </div>
      </a>
    ))}
  </div>

  <footer class="r-footer" style="background:var(--g);">
    <a href="/" style="text-decoration:none;font-family:var(--ff);font-size:14px;letter-spacing:.08em;text-transform:uppercase;color:var(--p);display:flex;align-items:center;gap:10px;">
      <span style="display:inline-block;width:7px;height:7px;background:var(--gs);flex-shrink:0;"></span>
      <span style="font-weight:300;">WATCH</span><span style="font-weight:500;color:var(--gs);">HAIKUS</span>
    </a>
    <span style="font-family:var(--ff);font-size:14px;font-style:italic;color:var(--gd);">Reading room for watches.</span>
    <nav style="display:flex;gap:28px;flex-wrap:wrap;">
      <a href="/essays" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">Essays</a>
      <a href="/haikus" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">Haikus</a>
      <a href="/available" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">Available</a>
      <a href="/about" style="font-family:var(--fm);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);text-decoration:none;">About</a>
    </nav>
  </footer>

</BaseLayout>
