---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';

const essays = await getCollection('essays');
const sorted = essays.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout title="Essays">

  <Header active="Essays" />

  <div style="border-bottom:1px solid var(--rule);padding:10px 32px;border-left:6px solid var(--g);">
    <span style="font-family:var(--fm);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--mute);">Essays — {sorted.length} pieces across {[...new Set(sorted.map(e => e.data.series))].length} series</span>
  </div>

  <section style="padding:56px 64px 48px;border-bottom:1px solid var(--rule);">
    <div style="font-family:var(--ff);font-size:44px;font-weight:300;font-style:italic;line-height:1.45;color:var(--ink);">
      We don't describe watches.<br>We <em style="font-style:normal;color:var(--g);font-weight:400;">argue</em> them.
    </div>
  </section>

  <div style="padding:44px 32px;">
    {sorted.map((essay, i) => (
      <a href={`/essays/${essay.slug}`} style="text-decoration:none;display:grid;grid-template-columns:110px 1fr;align-items:start;border-bottom:1px solid var(--rule);padding:32px 0;gap:0;">
        <div style="padding-right:28px;border-right:1px solid var(--rule);">
          <div style="font-family:var(--fm);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--g);margin-bottom:8px;font-weight:500;">Series {String(essay.data.seriesNumber).padStart(2,'0')}</div>
          <div style="font-family:var(--ff);font-size:48px;font-weight:300;color:var(--g);line-height:1;">{String(i + 1).padStart(2,'0')}</div>
        </div>
        <div style="padding-left:28px;">
          <div style="font-family:var(--fm);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--warm);margin-bottom:12px;">{essay.data.series} · {essay.data.readingTime}</div>
          <div style="font-family:var(--ff);font-size:24px;font-weight:400;line-height:1.3;color:var(--ink);margin-bottom:10px;">{essay.data.title}</div>
          <div style="font-family:var(--ff);font-size:16px;font-style:italic;font-weight:300;color:var(--mute);line-height:1.6;">{essay.data.subtitle}</div>
        </div>
      </a>
    ))}
  </div>

  <footer style="padding:32px;display:flex;align-items:center;justify-content:space-between;background:var(--g);">
    <div style="font-family:var(--ff);font-size:14px;letter-spacing:.1em;text-transform:uppercase;color:var(--p);display:flex;align-items:center;gap:10px;">
      <span style="display:inline-block;width:8px;height:8px;background:#A8C5A0;flex-shrink:0;"></span>
      <span style="font-weight:300;">WATCH</span><span style="font-weight:500;color:#A8C5A0;">HAIKUS</span>
    </div>
    <div style="font-family:var(--ff);font-size:14px;font-style:italic;color:#6E9178;">Reading room for watches.</div>
    <div style="display:flex;gap:24px;">
      <a href="/essays" style="font-family:var(--fm);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:#6E9178;text-decoration:none;">Essays</a>
      <a href="/haikus" style="font-family:var(--fm);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:#6E9178;text-decoration:none;">Haikus</a>
      <a href="/available" style="font-family:var(--fm);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:#6E9178;text-decoration:none;">Available</a>
      <a href="/about" style="font-family:var(--fm);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:#6E9178;text-decoration:none;">About</a>
    </div>
  </footer>

</BaseLayout>
