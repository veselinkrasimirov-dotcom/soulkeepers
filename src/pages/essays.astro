---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const essays = await getCollection('essays');
const sorted = essays.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout title="Essays">

  <Header active="Essays" />

  <div class="r-dateline" style="border-bottom:1px solid var(--rule);">
    <span style="font-family:var(--fm);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--mute);">Essays — {sorted.length} pieces across {[...new Set(sorted.map(e => e.data.series))].length} series</span>
  </div>

  <section class="r-section-hero" style="border-bottom:1px solid var(--rule);">
    <div class="r-label" style="margin-bottom:28px;color:var(--gd);">Long form</div>
    <div class="r-section-title" style="font-family:var(--ff);font-size:52px;font-weight:300;font-style:italic;line-height:1.35;color:var(--ink);max-width:640px;">
      We don't describe watches.<br>We <em style="font-style:normal;color:var(--g);font-weight:400;">argue</em> them.
    </div>
  </section>

  <div class="r-pad">
    {sorted.map((essay, i) => (
      <a href={`/essays/${essay.slug}`} class="r-grid-essay r-card" style="text-decoration:none;border-bottom:1px solid var(--rule);padding:36px 0;">
        <div class="r-essay-num" style="padding-right:28px;border-right:1px solid var(--rule);">
          <div style="font-family:var(--fm);font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--gd);margin-bottom:10px;">Series</div>
          <div style="font-family:var(--ff);font-size:52px;font-weight:300;color:var(--g);line-height:1;">{String(essay.data.seriesNumber).padStart(2,'0')}</div>
        </div>
        <div class="r-essay-body" style="padding-left:32px;">
          <div style="font-family:var(--fm);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--warm);margin-bottom:14px;display:flex;align-items:center;gap:10px;">
            <span style="display:inline-block;width:14px;height:1px;background:var(--warm);flex-shrink:0;"></span>
            {essay.data.series} · {essay.data.readingTime}
          </div>
          <div style="font-family:var(--ff);font-size:26px;font-weight:400;line-height:1.25;color:var(--ink);margin-bottom:12px;">{essay.data.title}</div>
          <div style="font-family:var(--ff);font-size:16px;font-style:italic;font-weight:300;color:var(--mute);line-height:1.65;">{essay.data.subtitle}</div>
          {essay.data.image && (
            <img src={essay.data.image} alt={essay.data.imageAlt ?? essay.data.title} style="margin-top:16px;width:100%;max-width:320px;aspect-ratio:16/9;object-fit:cover;display:block;" />
          )}
        </div>
      </a>
    ))}
  </div>

  <Footer />

</BaseLayout>
